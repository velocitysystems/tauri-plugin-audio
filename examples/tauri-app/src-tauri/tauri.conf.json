{
   "productName": "tauri-app",
   "version": "0.1.0",
   "identifier": "com.silvermine.tauri-plugin-audio-demo",
   "build": {
      "beforeDevCommand": "npm run vite",
      "beforeBuildCommand": "npm run build",
      "devUrl": "http://localhost:1420",
      "frontendDist": "../dist"
   },
   "app": {
      "windows": [
         {
            "title": "Audio Player Demo",
            "width": 700,
            "height": 360,
            "resizable": true,
            "fullscreen": false
         }
      ],
      "security": {
         "csp": null
      }
   },
   "bundle": {
      "active": true,
      "targets": "all",
      "icon": [
         "icons/32x32.png",
         "icons/128x128.png",
         "icons/128x128@2x.png",
         "icons/icon.icns",
         "icons/icon.ico"
      ]
   }
}
